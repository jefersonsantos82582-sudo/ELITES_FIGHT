# ==================== FIREBASE ====================
# Firebase Service Account JSON (obtenha em https://console.firebase.google.com)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"elites-fight","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}
FIREBASE_PROJECT_ID=elites-fight

# ==================== DATABASE ====================
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/elites_fight

# ==================== MERCADO PAGO ====================
# Access Token do Mercado Pago (obtenha em https://www.mercadopago.com.br/developers/panel)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR_XXXXXXXXXXXX

# Chave Pública do Mercado Pago (para o frontend)
VITE_MERCADO_PAGO_PUBLIC_KEY=APP_USR_XXXXXXXXXXXX

# ==================== GOOGLE OAUTH ====================
# Google OAuth credentials (obtenha em https://console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx

# ==================== AWS S3 (Armazenamento de Arquivos) ====================
# AWS credentials para armazenamento de planilhas geradas
AWS_ACCESS_KEY_ID=sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=seu-bucket-name

# ==================== ADMIN CONFIGURATION ====================
# Chave de acesso para o painel administrativo (mínimo 8 caracteres)
# IMPORTANTE: Use uma chave forte e única em produção
ADMIN_KEY=your_secure_admin_key_here_min_8_chars

# ==================== APPLICATION ====================
NODE_ENV=development
PORT=3000
